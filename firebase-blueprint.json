{
  "entities": {
    "User": {
      "title": "User Profile and Stats",
      "description": "Stores UPSC aspirant performance metrics and progress.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase Auth UID" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActiveDate": { "type": "string", "format": "date-time" },
        "totalQuestionsAttempted": { "type": "integer" },
        "correctAnswers": { "type": "integer" },
        "testHistory": { "type": "array" }
      },
      "required": ["userId", "xp", "level", "streak"]
    },
    "Post": {
      "title": "Forum Post",
      "description": "A discussion topic in the community forum.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Current Affairs", "Strategy", "Subject Doubts", "General"] },
        "upvotes": { "type": "array", "description": "Array of user IDs who upvoted" },
        "commentCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "content", "category", "createdAt"]
    },
    "Comment": {
      "title": "Forum Comment",
      "description": "A reply to a forum post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "content", "createdAt"]
    },
    "SavedQuestion": {
      "title": "Saved Question",
      "description": "A difficult question saved by the user for later review.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "questionData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "questionData", "createdAt"]
    },
    "StudyPlan": {
      "title": "AI Study Plan",
      "description": "A personalized study schedule generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planData": { "type": "object" },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planData", "generatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User statistics and progress."
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Community forum posts."
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a forum post."
    },
    "saved_questions/{saveId}": {
      "schema": "SavedQuestion",
      "description": "User's saved questions shelf."
    },
    "study_plans/{planId}": {
      "schema": "StudyPlan",
      "description": "User's AI-generated study plans."
    }
  }
}
